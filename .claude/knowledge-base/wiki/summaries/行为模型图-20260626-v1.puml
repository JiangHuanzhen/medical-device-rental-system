@startuml
|销售|
start
:发起设备出库申请;
|库房人员|
:检查设备状态;
if (设备状态为“在库”且合规?) then (是)
  |库房人员|
  :执行正常出库流程;
  stop
else (否)
  :检查设备状态异常原因;
  if (异常原因为“校准过期”?) then (是)
    |销售|
    :收到“设备状态异常”警告;
    :填写“紧急关联原因”;
    |系统|
    :生成“高风险设备使用”工单;
    :启动24小时倒计时;
    fork
      :正常计算设备使用费用;
    fork again
      :向财务部门生成风险预警记录;
    end fork
    |财务经理|
    :审批紧急出库申请;
    if (审批通过?) then (是)
      |库房人员|
      :执行特殊出库;
      |系统|
      :记录“非正常放行”;
      :在合同首页添加“设备状态警告”标识;
      note right: 边界路径：设备在24小时内归还并完成校准
      |运维工程师|
      :接收工单，跟进校准;
      if (24小时内收到校准报告?) then (是)
        :核对报告有效性;
        :在系统内点击“解除限制”;
        |系统|
        :解除设备限制，合同自动解冻;
        :将记录写入“维修知识库”;
        stop
      else (否)
        |系统|
        :自动冻结该设备的所有关联合同;
        :生成高优先级故障单;
        |运维工程师|
        :远程或到场锁定设备功能;
        stop
      endif
    else (否)
      |销售|
      :收到“出库申请被拒”通知;
      stop
    endif
  else (否)
    if (异常原因为“误标”?) then (是)
      |库房主管|
      :核实实物状态无误;
      :单人纠正设备状态;
      :执行出库;
      stop
    else (否)
      :其他异常情况处理;
      stop
    endif
  endif
endif

@enduml

@startuml
|销售|
start
:发起设备出库申请;
|系统|
:自动检测设备附件完整性;
if (所有附件状态为“完好”?) then (是)
  |库房人员|
  :执行正常出库流程;
  stop
else (否)
  :列出缺失/损坏附件清单;
  :根据附件分级规则判断;
  if (缺失附件为“关键附件”?) then (是)
    |系统|
    :强制阻止出库;
    :向销售发送“附件缺失，无法出库”通知;
    stop
  else (否)
    if (缺失附件为“非关键附件”?) then (是)
      |销售|
      :收到“附件缺失警告”;
      :与客户沟通确认;
      if (客户允许暂缓补全?) then (是)
        |销售|
        :在系统中记录“待补”;
        |库房人员|
        :执行出库，并在出库单上注明;
        stop
      else (否)
        |销售|
        :取消出库申请，等待补全附件;
        stop
      endif
    else (否)
      :其他附件问题处理;
      stop
    endif
  endif
endif

@enduml

@startuml
|库房人员|
start
:发起设备报废申请;
|系统|
:将设备状态自动标记为“待报废”;
:限制设备参与租赁、校准提醒等业务;
|审批领导|
:收到报废审批通知;
if (审批通过?) then (是)
  |系统|
  :将设备状态更新为“报废”;
  :从可用库存中移除;
  stop
else (否)
  if (审批卡住超过30天?) then (是)
    note right: 边界路径：审批流程长期未完成
    |系统|
    :自动向审批领导发送催办通知;
    :保持设备为“待报废”状态;
    |库房人员|
    :在盘点时手工备注“待报废”;
    :等待审批结果;
    stop
  else (否)
    |系统|
    :保持设备为“待报废”状态;
    |库房人员|
    :等待审批结果;
    stop
  endif
endif

@enduml

@startuml
actor 销售
actor 库房人员
actor 财务经理
actor 运维工程师
participant "Controller: OutboundController" as Controller
participant "Service: EquipmentService" as Service
participant "Service: ContractService" as ContractService
participant "Service: AlertService" as AlertService
participant "Repository: EquipmentRepository" as EquipmentRepo
participant "Repository: ContractRepository" as ContractRepo

销售 -> Controller: 发起出库申请(设备ID, 合同ID)
Controller -> Service: checkEquipmentStatus(设备ID)
Service -> EquipmentRepo: findById(设备ID)
EquipmentRepo --> Service: 设备实体
Service -> Service: 判断设备状态
alt 设备状态正常
    Service --> Controller: 状态正常
    Controller -> Controller: 执行正常出库逻辑
    Controller --> 销售: 出库成功
else 设备状态异常(校准过期)
    Service --> Controller: 状态异常(校准过期)
    Controller --> 销售: 返回警告信息
    销售 -> Controller: 填写紧急关联原因
    Controller -> Service: createEmergencyOutbound(设备ID, 合同ID, 原因)
    Service -> AlertService: createHighRiskWorkOrder(设备ID, 原因)
    Service -> ContractService: markContractWithWarning(合同ID)
    Service -> Service: start24HourTimer(设备ID)
    Service -> EquipmentRepo: save(设备实体)
    Service --> Controller: 紧急出库单创建成功
    Controller --> 销售: 出库申请已提交，等待审批
    Controller --> 财务经理: 发送审批请求
    财务经理 -> Controller: 审批通过
    Controller -> Service: approveEmergencyOutbound(设备ID)
    Service -> EquipmentRepo: updateStatus(设备ID, "非正常放行")
    Service -> ContractService: calculateAndRecordFee(合同ID)
    Service -> AlertService: sendFinancialRiskAlert(设备ID, 合同ID)
    Service --> Controller: 审批完成
    Controller --> 库房人员: 执行出库指令
    库房人员 -> Controller: 出库完成确认
    Controller -> Service: confirmOutbound(设备ID)
    Service -> Service: 记录出库日志
    Service --> Controller: 确认成功
    Controller --> 销售: 设备已出库
    loop 24小时倒计时
        Service -> Service: 检查校准报告
        alt 24小时内收到校准报告
            运维工程师 -> Controller: 上传校准报告
            Controller -> Service: verifyCalibrationReport(设备ID, 报告)
            Service -> EquipmentRepo: updateCalibrationInfo(设备ID, 报告)
            Service -> ContractService: unFreezeContract(合同ID)
            Service -> AlertService: closeHighRiskWorkOrder(设备ID)
            Service --> Controller: 设备已恢复正常
            Controller --> 运维工程师: 解除限制成功
        else 24小时超时
            Service -> ContractService: freezeContract(合同ID)
            Service -> AlertService: createHighPriorityFaultOrder(设备ID)
            Service --> Controller: 设备已冻结
            Controller --> 运维工程师: 生成高优先级故障单
        end
    end
end

@enduml

@startuml
!define table(x) class x << (T,#FFAAAA) >>

table(设备) {
  + 设备ID (PK)
  --
  设备名称
  品牌型号
  出厂编号
  注册证号
  设备价值
  租赁频次
  当前状态: 在库/出租/维修/待报废/报废
  校准有效期
  是否合规
  创建时间
  更新时间
}

table(附件) {
  + 附件ID (PK)
  --
  附件名称
  附件条码/RFID
  附件类型: 关键/非关键
  当前状态: 完好/破损/缺失/待校准
  关联设备ID (FK)
  创建时间
  更新时间
}

table(合同) {
  + 合同ID (PK)
  --
  合同编号
  客户ID (FK)
  开始日期
  结束日期
  合同状态: 进行中/已结束/已冻结
  设备状态警告标识: 是/否
  创建时间
  更新时间
}

table(合同_设备关联) {
  + 关联ID (PK)
  --
  合同ID (FK)
  设备ID (FK)
  关联类型: 正常/紧急
  紧急关联原因
  关联时间
}

table(高风险工单) {
  + 工单ID (PK)
  --
  设备ID (FK)
  合同ID (FK)
  工单类型: 校准过期/附件缺失
  工单状态: 待处理/处理中/已完成
  创建时间
  24小时倒计时截止时间
  处理人ID (FK)
  处理结果
}

table(校准记录) {
  + 记录ID (PK)
  --
  设备ID (FK)
  校准日期
  校准结果
  有效期至
  校准报告附件
  上传人ID (FK)
  审核人ID (FK)
  审核状态: 待审核/已通过/已拒绝
}

table(审批记录) {
  + 审批ID (PK)
  --
  关联业务类型: 报废/紧急出库
  关联业务ID
  审批人ID (FK)
  审批结果: 通过/拒绝/待审批
  审批意见
  审批时间
}

table(设备状态变更日志) {
  + 日志ID (PK)
  --
  设备ID (FK)
  变更前状态
  变更后状态
  变更原因
  操作人ID (FK)
  变更时间
}

设备 ||--o{ 附件 : "包含"
设备 ||--o{ 合同_设备关联 : "关联"
合同 ||--o{ 合同_设备关联 : "关联"
设备 ||--o{ 高风险工单 : "产生"
设备 ||--o{ 校准记录 : "拥有"
设备 ||--o{ 设备状态变更日志 : "记录"
合同 ||--o{ 高风险工单 : "关联"

@enduml