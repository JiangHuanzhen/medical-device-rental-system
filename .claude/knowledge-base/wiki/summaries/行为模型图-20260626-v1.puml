@startuml
|#LightBlue|库房人员|
start
:接收归还设备;
:核对附件清单;
:检查设备外观与功能;

|#LightGreen|系统|
:记录验收开始时间;

|#LightBlue|库房人员|
if (附件是否齐全?) then (是)
  :标记附件状态为“正常”;
else (否)
  :拍照留存证据;
  :在系统中标记「附件异常」;
  |#LightGreen|系统|
  :自动通知销售/客服团队;
  |#LightBlue|库房人员|
endif

if (设备是否有物理损伤或功能异常?) then (否)
  :标记设备状态为“正常”;
else (是)
  :拍照记录损坏部位(带水印和时间戳);
  :录入“验收异常记录”;
  |#LightGreen|系统|
  :根据预设规则判断;
  if (维修费用 < 设备残值 * 50%?) then (是)
    :自动生成“维修工单”;
    :标记设备状态为“待维修”;
  else (否)
    :触发“报废审批流程”;
    :标记设备状态为“待报废”;
  endif
  |#LightBlue|库房人员|
endif

|#LightGreen|系统|
:生成统一的“设备归还验收单”;

|#LightBlue|库房人员|
if (设备状态为“待维修”或“待报废”?) then (是)
  :确认设备不可用;
  |#LightGreen|系统|
  :禁止客户意向单锁定该设备;
  :标记设备为“不可用”;
else (否)
  :确认设备状态为“在库”;
endif

|#LightBlue|库房人员|
:完成验收流程;
stop

@enduml

@startuml
|#LightYellow|招商业务员|
start
:获取招标公告;
:使用“招投标关联”功能匹配设备;

|#LightGreen|系统|
:展示匹配结果;

|#LightYellow|招商业务员|
:制定租赁方案;
if (客户是否有紧急截止日期?) then (是)
  :为合同打上“限时标识”;
  :提交方案并走“加签通道”;
else (否)
  :提交方案审批;
endif

|#LightGreen|系统|
if (合同有“限时标识”?) then (是)
  :强制审批人在48小时内反馈;
else (否)
  :进入正常审批流程;
endif

|#LightYellow|招商业务员|
:同步提交“意向锁定单”;

|#LightGreen|系统|
:检查库存;
if (库存充足?) then (是)
  :标记设备为“意向锁定”;
else (否)
  :通知招商业务员库存不足;
  |#LightYellow|招商业务员|
  if (合同是否允许替代型号?) then (是)
    :与客户协商使用替代型号;
    if (客户同意?) then (是)
      :更新设备清单;
      :重新提交意向锁定;
    else (否)
      :与客户协商延期或放弃;
    endif
  else (否)
    :与客户协商延期或放弃;
  endif
endif

|#LightGreen|系统|
if (审批通过?) then (是)
  :生成租赁合同;
  :将招投标项目进度与合同关联;
else (否)
  :通知招商业务员审批驳回;
  |#LightYellow|招商业务员|
  :修改方案并重新提交;
endif

stop

@enduml

@startuml
|#LightBlue|库房人员|
start
:接收新设备;
:核对设备信息(品牌型号、出厂编号等);

|#LightGreen|系统|
if (设备信息是否完整?) then (是)
  :创建设备档案;
else (否)
  :提示信息缺失，要求补充;
  |#LightBlue|库房人员|
  :补充缺失信息;
endif

|#LightBlue|库房人员|
:分配库房库位;
:完成实物与库位绑定;

|#LightGreen|系统|
:记录库位信息;

|#LightBlue|库房人员|
:上传校准证书/检测报告;

|#LightGreen|系统|
if (校准证书是否在有效期内?) then (是)
  :记录校准有效期;
  :设置到期前30/15/7天预警;
else (否)
  :标记校准状态为“异常”;
  :触发预警通知;
endif

|#LightBlue|库房人员|
if (设备是否有特殊状态?) then (待报废)
  :走报废审批流程;
  |#LightGreen|系统|
  :标记设备状态为“报废”;
else (正常)
  :确认设备状态为“在库”;
  |#LightGreen|系统|
  :标记设备状态为“在库”;
endif

|#LightBlue|库房人员|
:完成入库流程;
stop

@enduml

@startuml
actor "库房人员" as WH
participant "归还验收Controller" as RC
participant "设备Service" as ES
participant "附件Service" as AS
participant "通知Service" as NS
participant "设备Repository" as ER
participant "附件Repository" as AR

WH -> RC: 提交归还验收请求(设备ID, 附件清单, 验收结果)
activate RC

RC -> ES: 获取设备信息(设备ID)
activate ES
ES -> ER: findById(设备ID)
ER --> ES: 返回设备信息
ES --> RC: 返回设备信息
deactivate ES

RC -> AS: 核对附件(设备ID, 附件清单)
activate AS
AS -> AR: checkAccessories(设备ID, 附件清单)
AR --> AS: 返回核对结果
alt 附件齐全
  AS --> RC: 附件状态正常
else 附件缺失或损坏
  AS --> RC: 附件状态异常
  RC -> NS: 发送通知(销售/客服团队, 附件异常)
  activate NS
  NS --> RC: 通知发送成功
  deactivate NS
end
deactivate AS

alt 设备正常
  RC -> ES: 更新设备状态(设备ID, “在库”)
  activate ES
  ES -> ER: updateStatus(设备ID, “在库”)
  ER --> ES: 更新成功
  deactivate ES
else 设备损坏
  RC -> ES: 判断处理方式(设备ID, 损坏描述)
  activate ES
  alt 维修费用 < 残值50%
    ES -> ER: updateStatus(设备ID, “待维修”)
    ER --> ES: 更新成功
    ES --> RC: 生成维修工单
  else 维修费用 >= 残值50%
    ES -> ER: updateStatus(设备ID, “待报废”)
    ER --> ES: 更新成功
    ES --> RC: 触发报废流程
  end
  deactivate ES
end

RC -> RC: 生成“设备归还验收单”
RC --> WH: 返回验收结果及单据
deactivate RC

@enduml

@startuml
!define table(x) class x << (T,#FFAAAA) >>

table(设备档案) {
  + 设备ID (PK)
  --
  品牌型号
  出厂编号
  注册证号
  当前状态: 在库/出租/维修/校准/报废
  校准有效期
  库位ID (FK)
}

table(库位) {
  + 库位ID (PK)
  --
  货架编号
  区域码
}

table(附件) {
  + 附件ID (PK)
  --
  附件名称
  规格
  数量
  状态: 正常/异常/待调拨
  设备ID (FK)
}

table(设备归还验收单) {
  + 验收单ID (PK)
  --
  设备ID (FK)
  验收时间
  验收结果: 正常/异常
  附件状态: 正常/异常
  损坏描述
  附件异常描述
}

table(维修工单) {
  + 工单ID (PK)
  --
  设备ID (FK)
  创建时间
  维修描述
  状态: 待处理/处理中/已完成
}

table(报废审批) {
  + 审批ID (PK)
  --
  设备ID (FK)
  申请时间
  审批状态: 待审批/已批准/已拒绝
}

table(租赁合同) {
  + 合同ID (PK)
  --
  客户信息
  租赁设备清单
  合同状态: 审批中/已生效/已结束
  招投标项目ID (FK)
}

table(招投标项目) {
  + 项目ID (PK)
  --
  招标公告信息
  项目进度: 投标/中标/合同签订
  需求变更记录
}

table(意向锁定单) {
  + 锁定单ID (PK)
  --
  合同ID (FK)
  设备ID (FK)
  锁定时间
  状态: 有效/已释放
}

设备档案 ||--o{ 附件 : 包含
设备档案 }o--|| 库位 : 存放于
设备档案 ||--o{ 设备归还验收单 : 关联
设备档案 ||--o{ 维修工单 : 触发
设备档案 ||--o{ 报废审批 : 触发
租赁合同 ||--o{ 意向锁定单 : 包含
意向锁定单 }o--|| 设备档案 : 锁定
租赁合同 }o--|| 招投标项目 : 关联

@enduml