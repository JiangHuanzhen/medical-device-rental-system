@startuml
left to right direction
skinparam packageStyle rectangle
actor "招商业务员" as Sales
actor "库房人员" as Warehouse
actor "运维工程师" as Ops
actor "财务人员" as Finance
actor "科室主任" as DeptHead
actor "质控部门" as QC

rectangle "设备管理" {
  usecase "UC1: 设备校准到期预警与管控" as UC1
  usecase "UC2: 发起紧急出库审批" as UC2
  usecase "UC3: 执行紧急出库审批" as UC3
  usecase "UC4: 设备归还检测" as UC4
  usecase "UC5: 设备归还异常处理" as UC5
  usecase "UC6: 设备归还复核" as UC6
  usecase "UC7: 查看设备校准状态" as UC7
  usecase "UC8: 管理设备检测清单模板" as UC8
  usecase "UC9: 处理设备归还财务审核" as UC9
}

Sales --> UC1
Sales --> UC2
Sales --> UC4
Sales --> UC7

Warehouse --> UC1
Warehouse --> UC3
Warehouse --> UC6
Warehouse --> UC7

Ops --> UC8
Ops --> UC5

Finance --> UC9
Finance --> UC7

DeptHead --> UC3
QC --> UC3

UC2 .> UC3 : <<include>>
